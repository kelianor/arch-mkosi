#!/bin/bash
set -e

# Create a "Factory" systemd confext image
LOCATION="/usr/lib/confexts/"
NAME="Factory"

mkdir -p "$LOCATION/$NAME/etc/extension-release.d/"
touch "$LOCATION/$NAME/etc/extension-release.d/extension-release.$NAME"

tee "$LOCATION/$NAME/etc/extension-release.d/extension-release.$NAME" <<EOF
$(grep "^ID=" /etc/os-release)
$(grep "^VERSION_ID=" /etc/os-release)
CONFEXT_LEVEL=1.0
EOF

# Copy all files from /etc to a "Factory" systemd confext image
cp -r "/etc/" $LOCATION/$NAME
